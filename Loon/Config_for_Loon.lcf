# ===== [Host] =====
# Host/DNS 映射区；为指定域名指定 DNS 服务器
[Host]
*.icloud.com = server:119.29.29.29
*.icloud.com.cn = server:119.29.29.29
*.tencent.com = server:119.29.29.29
*.weixin.com = server:119.29.29.29
# ===== [Rewrite] =====
# URL 重写区；
[Rewrite]
# URL Rewrite；命中左侧正则后执行 302 跳转到右侧地址
^https?:\/\/(www.)?(g|google)\.cn 302 https://www.google.com

# ===== [Script] =====
# 脚本区；
[Script]
# AppStore 限免推送
cron "17 17 * * *" script-path=https://raw.githubusercontent.com/deezertidal/private/main/appsdoor.js, timeout=300, tag=AppStore限免APP

# ===== [Plugin] =====

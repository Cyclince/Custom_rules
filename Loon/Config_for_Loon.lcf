# ===== [Remote Filter] =====
# 远程节点筛选器；用 NameRegex 按节点名称提取香港、台湾、日本等地区节点池
[Remote Filter]
# 节点池
香港节点池 = NameRegex, FilterKey = "(🇭🇰|港|\bHK(?:[-_ ]?\d+(?:[-_ ]?[A-Za-z]{2,})?)?\b|hk|Hong Kong|HongKong|hongkong|HONG KONG|HONGKONG|深港|HKG|九龙|Kowloon|新界|沙田|荃湾|葵涌)"
台湾节点池 = NameRegex, FilterKey = "(🇹🇼|🇼🇸|台|新北|彰化|\bTW(?:[-_ ]?\d+(?:[-_ ]?[A-Za-z]{2,})?)?\b|Taiwan|TAIWAN|TWN|TPE|ROC)"
日本节点池 = NameRegex, FilterKey = "(🇯🇵|日本|川日|东京|大阪|泉日|埼玉|沪日|深日|(?<!尼|-)日|\bJP(?:[-_ ]?\d+(?:[-_ ]?[A-Za-z]{2,})?)?\b|Japan|JAPAN|JPN|NRT|HND|KIX|TYO|OSA|关西|Kansai|KANSAI)"
韩国节点池 = NameRegex, FilterKey = "(🇰🇷|\bKR(?:[-_ ]?\d+(?:[-_ ]?[A-Za-z]{2,})?)?\b|Korea|KOREA|KOR|首尔|韩|韓|春川|Chuncheon|ICN)"
狮城节点池 = NameRegex, FilterKey = "(🇸🇬|新加坡|坡|狮城|\bSG(?:[-_ ]?\d+(?:[-_ ]?[A-Za-z]{2,})?)?\b|Singapore|SINGAPORE|SIN)"
美国节点池 = NameRegex, FilterKey = "(🇺🇸|美|波特兰|达拉斯|俄勒冈|凤凰城|费利蒙|硅谷|拉斯维加斯|洛杉矶|圣何塞|圣克拉拉|西雅图|芝加哥|纽约|纽纽|亚特兰大|迈阿密|华盛顿|\bUS(?:[-_ ]?\d+(?:[-_ ]?[A-Za-z]{2,})?)?\b|United States|UnitedStates|UNITED STATES|USA|America|AMERICA|JFK|EWR|IAD|ATL|ORD|MIA|NYC|LAX|SFO|SEA|DFW|SJC)"
英国节点池 = NameRegex, FilterKey = "(🇬🇧|英国|Britain|United Kingdom|UNITED KINGDOM|England|伦敦|曼彻斯特|Manchester|\bUK(?:[-_ ]?\d+(?:[-_ ]?[A-Za-z]{2,})?)?\b|GBR|LHR|MAN)"
法国节点池 = NameRegex, FilterKey = "(🇫🇷|法国|\bFR(?:[-_ ]?\d+(?:[-_ ]?[A-Za-z]{2,})?)?\b|France|FRANCE|FRA|巴黎|马赛|Marseille|CDG|MRS)"
德国节点池 = NameRegex, FilterKey = "(🇩🇪|德国|Germany|GERMANY|\bDE(?:[-_ ]?\d+(?:[-_ ]?[A-Za-z]{2,})?)?\b|DEU|柏林|法兰克福|慕尼黑|Munich|MUC)"
加拿大节点池 = NameRegex, FilterKey = "(🇨🇦|加拿大|\bCA(?:[-_ ]?\d+(?:[-_ ]?[A-Za-z]{2,})?)?\b|Canada|CANADA|CAN|渥太华|温哥华|卡尔加里|蒙特利尔|Montreal|YVR|YYZ|YUL)"
俄罗斯节点池 = NameRegex, FilterKey = "(🇷🇺|(?<!白)俄罗斯|(?<!白)俄|莫斯科|圣彼得堡|新西伯利亚|海参崴|符拉迪沃斯托克|哈巴罗夫斯克|伯力|\bRU(?:[-_ ]?\d+)?\b|Russia)"
其他地区节点池 = NameRegex, FilterKey = "(^(?!.*(wrt|港|HK|Hong Kong|HKG|🇭🇰|美|US|USA|America|🇺🇸|日本|JP|Japan|🇯🇵|新加坡|SG|Singapore|🇸🇬|台|TW|Taiwan|🇹🇼|韩国|KR|Korea|🇰🇷|加拿大|CA|Canada|🇨🇦|英国|UK|GBR|Britain|🇬🇧|法国|FR|France|🇫🇷|德国|DE|Germany|俄罗斯|RU|Russia|🇷🇺)).*)"

